default_platform(:android)

platform :android do
  desc "Run KtLint"
  lane :ktlint do
    gradle(
      tasks: ["app:ktlintCheck"],
      flags: "--no-daemon"
    )
  end

  desc "Run unit tests"
  lane :unit_test do
    gradle(
      tasks: ["app:testDebugUnitTest"],
      flags: "--no-daemon"
    )
  end

  desc "Run CI checks (KtLint + Unit Test)"
  lane :ci do
    ktlint
    unit_test
  end
end
