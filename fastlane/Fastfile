default_platform(:android)

platform :android do
  desc "Run KtLint"
  lane :ktlint do
    gradle(
      tasks: ["app:ktlintCheck"],
      flags: "--no-daemon"
    )
  end

  desc "Run detekt"
  lane :detekt do
    gradle(
      tasks: ["app:detekt"],
      flags: "--no-daemon"
    )
  end

  desc "Run Android Lint (prod)"
  lane :lint do
    gradle(
      tasks: ["app:lintProdDebug"],
      flags: "--no-daemon"
    )
  end

  desc "Run static analysis (KtLint + detekt + Android Lint)"
  lane :static_analysis do
    ktlint
    detekt
    lint
  end

  # unit test は JVM 上で実行され R8/minify を通らないため debug variant のみで全テストをカバーする。
  # release:true のときは R8/minify ビルドが壊れていないかを assembleProdRelease で追加検証する。
  desc "Run unit tests (debug only by default; pass release:true to also verify the release build)"
  lane :unit_test do |options|
    tasks = ["app:testProdDebugUnitTest"]
    tasks << "app:assembleProdRelease" if options[:release]
    gradle(
      tasks: tasks,
      flags: "--no-daemon"
    )
  end

  desc "Generate Kover XML and HTML reports for prodDebug"
  lane :coverage do
    gradle(
      tasks: ["app:koverXmlReportProdDebug", "app:koverHtmlReportProdDebug"],
      flags: "--no-daemon"
    )
  end

  desc "Run CI checks (KtLint + detekt + Android Lint + Unit Test)"
  lane :ci do
    static_analysis
    unit_test
  end

  desc "Run Android UI/Instrumentation tests"
  lane :android_test do
    gradle(
      tasks: ["app:connectedDevDebugAndroidTest"],
      flags: "--no-daemon"
    )
  end
end
