# リリース署名設定のサンプル。
# このファイルをコピーして keystore.properties を作成し、実際の値を設定してください。
# keystore.properties と鍵ファイル(*.jks/*.keystore)は .gitignore 済みで VCS には含めません。
#
#   cp keystore.properties.example keystore.properties
#
# keystore.properties が存在しない環境では release ビルドは未署名になります
# （ビルド自体は成功します）。

# キーストアファイルへのパス（プロジェクトルートからの相対パス、または絶対パス）
storeFile=release.jks

# キーストアのパスワード
storePassword=

# 署名鍵のエイリアス
keyAlias=

# 署名鍵のパスワード
keyPassword=
