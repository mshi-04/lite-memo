#!/bin/sh

if [ ! -f "./gradlew" ] || [ ! -x "./gradlew" ]; then
    echo "Error: ./gradlew not found or not executable."
    echo "Please ensure the project is properly set up."
    exit 1
fi

echo "Running KtLint format..."
./gradlew app:ktlintFormat --no-daemon -p .
if [ $? -ne 0 ]; then
    echo "KtLint format failed. Commit aborted."
    exit 1
fi

# Stage any files that KtLint reformatted so they are included in this commit.
git add -u
